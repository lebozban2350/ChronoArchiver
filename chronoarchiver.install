# ChronoArchiver pacman install hooks
# Updates icon cache so the application icon appears correctly in GNOME/KDE/etc.

post_install() {
    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache -f -t /usr/share/icons/hicolor 2>/dev/null || true
    fi
}

post_upgrade() {
    post_install
}
